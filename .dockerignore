.git
.gitignore

# Environment files
**/.env
**/.env.*
!**/.env.example

# Python artifacts
**/__pycache__
**/*.pyc
**/*.pyo
**/.pytest_cache
**/.venv
**/venv

# Backend specific
backend/instance/
backend/*.db
backend/.python-version

# Frontend specific
frontend/node_modules
frontend/dist

# Docs (only root-level, keep backend/README.md for pyproject.toml)
README.md
