# Environment Configuration
# Copy this file to .env and update values

# Database URL (SQLite for development)
DATABASE_URL=sqlite:///./sql_app.db

# Or use PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost/dbname

# Or use MySQL
# DATABASE_URL=mysql+pymysql://user:password@localhost/dbname

# Secret key for JWT tokens (CHANGE IN PRODUCTION!)
SECRET_KEY=your-secret-key-change-in-production

# JWT token expiration in minutes (default: 10080 = 7 days)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Server configuration
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Logger name — the root logger identifier used by the application,
# and also the log file name (without .log extension) when LOG_DIR is set.
# Default: model-link
# LOG_NAME=model-link

# Log directory (optional). When set, logs are written to both stderr and
# ``{LOG_DIR}/{LOG_NAME}.log`` with automatic rotation (50 MB per file, 5 backups).
# The directory will be created automatically.
# Examples:
#   LOG_DIR=/var/log/model-link       → /var/log/model-link/model-link.log
#   LOG_DIR=logs                      → logs/model-link.log
# LOG_DIR=

# Log format string (Python logging format syntax).
# Controls the structure of log messages — useful for log aggregators.
#
# Default: %(asctime)s [%(levelname)s] %(name)s: %(message)s
#
# Examples:
#   JSON (log aggregation):  LOG_FORMAT={"timestamp":"%(asctime)s","level":"%(levelname)s","logger":"%(name)s","message":"%(message)s"}
#   Minimal:                 LOG_FORMAT=[%(levelname)s] %(message)s
#   With file/line info:     LOG_FORMAT=%(asctime)s [%(levelname)s] %(name)s (%(filename)s:%(lineno)d): %(message)s
# LOG_FORMAT=

# Log date/time format string (Python strftime syntax).
# Default: %Y-%m-%d %H:%M:%S
# LOG_DATE_FORMAT=%Y-%m-%d %H:%M:%S

# ── SQLAlchemy Connection Pool ──────────────────────────────────────────────
# Number of core connections kept in the pool (default: 5)
# SQLALCHEMY_POOL_SIZE=5

# Additional connections beyond pool_size (default: 10)
# SQLALCHEMY_MAX_OVERFLOW=10

# Timeout in seconds for getting a connection from the pool (default: 30)
# SQLALCHEMY_POOL_TIMEOUT=30

# Recycle connections after N seconds to prevent stale connections (default: 1800)
# SQLALCHEMY_POOL_RECYCLE=1800

# Enable connection health checks before use (default: true)
# SQLALCHEMY_POOL_PRE_PING=true

# ── Request / Response Timeouts ─────────────────────────────────────────────
# Maximum request body size in bytes (default: 104857600 = 100 MB).
# Increase this if you need to send very large base64-encoded images/videos.
# MAX_CONTENT_LENGTH=104857600

# Maximum time in seconds to wait for the complete request body (default: 300).
# BODY_TIMEOUT=300

# Maximum time in seconds to wait for a complete response (default: 2400 = 40 min).
# AI model calls (chat, image/video/3D generation) can take a long time.
# Increase this if you work with slow generation or large media.
# RESPONSE_TIMEOUT=2400

# ── Leader Election (tooz) ──────────────────────────────────────────────────
# Coordination backend URL for distributed leader election.
# When not set, falls back to file:///tmp/model-link-coordinator (file-based, single-node mode).
# Examples:
#   file:///tmp/model-link-coordinator   – single-node / local dev (file-based, no external service)
#   redis://localhost:6379               – distributed via Redis
#   zookeeper://host1:2181,host2:2181    – distributed via ZooKeeper
#   etcd3+http://localhost:2379          – distributed via etcd v3
#   consul://localhost:8500              – distributed via Consul
#   mysql://user:pass@host/db            – distributed via MySQL
#   postgresql://user:pass@host/db       – distributed via PostgreSQL
# COORDINATOR_URL=

# Election group name (default: model-link-leader)
# ELECTION_GROUP=model-link-leader

# Unique node identifier (default: <hostname>-<pid>)
# NODE_ID=

# Heartbeat interval in seconds (default: 10)
# ELECTION_HEARTBEAT_INTERVAL=10

# ── Cache Middleware ────────────────────────────────────────────────────────
# Cache backend type: memory (default, in-process) or redis (distributed)
# CACHE_BACKEND=memory

# Cache TTL in seconds (default: 300 = 5 minutes)
# CACHE_TTL=300

# API Key cache TTL in seconds (default: 86400 = 24 hours)
# API key data changes infrequently but is read on every request,
# so a long TTL reduces DB load. Budget/usage updates keep it fresh in real-time.
# CACHE_APIKEY_TTL=86400

# Redis URL (only used when CACHE_BACKEND=redis)
# CACHE_REDIS_URL=redis://localhost:6379/0

# Redis key prefix (only used when CACHE_BACKEND=redis)
# CACHE_KEY_PREFIX=ml:

# ── Statistics Data Source ──────────────────────────────────────────────────
# Where the daily-consumption statistics are computed from.
#   db       aggregate from the local UsageRecord table (default)
#   metabase query a Metabase dataset card (see METABASE_* below)
# Only one source is active at a time; there is no automatic fallback.
# STATS_DATA_SOURCE=db

# Metabase endpoint + credentials (used only when STATS_DATA_SOURCE=metabase).
# METABASE_BASE_URL=https://kmb.example.com
# METABASE_API_KEY=
# Request timeout (seconds) for Metabase /api/dataset calls (default: 30)
# METABASE_TIMEOUT=30

# Source card + database identifiers in Metabase.
# METABASE_CARD_ID=15763
# METABASE_DATABASE_ID=13371347

# Stable field lib/uuid values for the columns exposed by the source card.
# Required when STATS_DATA_SOURCE=metabase. These identify the card columns in
# the new-format MBQL query; they are a property of the card schema.
# METABASE_FIELD_DS_UUID=5c6bddf7-f7cc-40a1-9892-15931084b009
# METABASE_FIELD_DS_TIME_UUID=ea042777-dc07-4fbe-bcc1-d54d5d21d5f8
